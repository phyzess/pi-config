# Pi Agent 配置环境变量
# 复制并填入真实值: cp config/env.example ~/.pi-agent-env
# 然后在 ~/.zshrc 中加: source ~/.pi-agent-env

# ---- MCP 私有服务器 (gitlab, atlassian, figma) ----
GITLAB_MCP_HOST=YOUR_GITLAB_MCP_HOST
GITLAB_READ_TOKEN=YOUR_GITLAB_READ_TOKEN

ATLASSIAN_MCP_HOST=YOUR_ATLASSIAN_MCP_HOST
CONFLUENCE_READ_TOKEN=YOUR_CONFLUENCE_READ_TOKEN
JIRA_READ_TOKEN=YOUR_JIRA_READ_TOKEN

FIGMA_API_KEY=YOUR_FIGMA_API_KEY

# ---- Pi 认证 (按需) ----
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
